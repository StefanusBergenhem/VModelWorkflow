# Front-matter slot-fill for an ADR.
# All required fields below; uncomment optional fields as applicable.

id: ADR-NNN-<kebab-slug>          # pattern: ADR-\d{3,}-[a-z0-9]+(-[a-z0-9]+)*
artifact_type: adr
title: "<active-voice noun phrase>"
status: proposed                  # proposed → accepted → superseded
date: YYYY-MM-DD                  # ISO date; first-draft date if proposed, acceptance date if accepted
scope_tags:                       # NON-EMPTY (refusal C/E gate)
  - "<scope>"
# affected_scopes:                # optional — when reach exceeds scope_tags
#   - "<scope>"
#   - "<scope>"
# supersedes: ADR-NNN-<old-slug>  # the predecessor this ADR replaces
# superseded_by: ADR-NNN-<new-slug>   # set on the predecessor when the chain advances
# recovery_status:                # retrofit only — map form preferred for per-field detail
#   context: unknown
#   alternatives_considered: unknown
#   rationale: unknown
#   consequences: unknown
