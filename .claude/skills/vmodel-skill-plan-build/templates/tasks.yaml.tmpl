# .vmodel/.build/tasks.yaml
# Generated by vmodel-skill-plan-build. Do not edit by hand — re-run the
# planner skill after spec changes. The orchestrator may update `status`
# fields in place; all other fields are planner-owned.
#
# Schema reference: .claude/skills/vmodel-skill-plan-build/references/tasks-schema.md

version: 1
build_run_id: "{{ build_run_id }}"        # format: YYYY-MM-DD-<6-char-hex>
plan_date: "{{ plan_date }}"              # ISO-8601 date of this plan run
project: "{{ project }}"                  # from .vmodel/config.yaml

# ── Implementation tasks (leaf scopes only) ────────────────────────────────
tasks:
  - id: "build-{{ scope_flattened }}"     # scope path with / replaced by -
    scope: "{{ scope }}"                  # path relative to scope_root
    type: leaf-implementation
    detailed_design: "{{ dd_id }}"        # id from detailed_design.md front-matter
    testspec: "{{ testspec_id }}"         # id from testspec.md front-matter
    governing_adrs:                       # from DD front-matter; empty list if none
      {{ governing_adrs | yaml_list_items }}
    files_to_touch: []                    # AUTHOR LEAVES EMPTY — implement-leaf populates
    depends_on:                           # omit block if no dependencies
      - id: "build-{{ dep_scope_flattened }}"
        strength: "{{ critical | helpful }}"
    estimates:
      complexity: "{{ low | medium | high }}"   # see dependency-inference.md §complexity-heuristic
    status: pending                       # orchestrator updates; planner always sets pending

# ── Stage groupings (topological sort result) ─────────────────────────────
# Each stage contains tasks whose dependencies are satisfied by prior stages.
# Tasks within a stage are safe to execute in parallel.
stages:
  - stage_id: 1
    tasks:
      {{ stage_1_task_ids | yaml_list_items }}
  # - stage_id: 2
  #   tasks: [...]

# ── Branch integration test stages ───────────────────────────────────────
# One entry per branch scope. Ordered deepest-first (highest path depth first).
# Root scope is NOT included here — it is in root_test_stage below.
branch_test_stages:
  - scope: "{{ branch_scope }}"
    type: branch-integration
    architecture: "{{ branch_arch_id }}"
    testspec: "{{ branch_testspec_id }}"  # omit if no testspec for this branch
    after_stage: {{ after_stage_n }}      # run after this implementation stage

# ── Root system test stage ────────────────────────────────────────────────
# Exactly one entry. Runs after all implementation stages complete.
root_test_stage:
  scope: ""                               # empty string = root scope
  type: root-system
  architecture: "{{ root_arch_id }}"      # omit if absent
  testspec: "{{ root_testspec_id }}"      # omit if absent
  requirements: "{{ root_reqs_id }}"      # omit if absent
  root_product: "{{ root_product_id }}"   # PD / needs / PB id; from config root_product.type
  after_stage: {{ total_impl_stages }}    # = count of stages entries above
