# feedback.yaml template — emitted ONLY for REJECTED verdicts.
# APPROVED writes no file (the impl's review-ready.yaml stays as the record).
# Write to: .vmodel/.build/tasks/<task-id>/feedback.yaml
# Consumed by: vmodel-skill-implement-leaf in fix mode (see its
#              references/fix-mode-taxonomy.md §2 for the canonical shape).

task_id: <task-id>                   # from current-task.yaml
scope: <scope-path>                  # e.g. auth/token-validator
layer: <leaf|branch|root>            # determined from task_type
verdict: REJECTED
attempt: <N>                         # current attempt number from current-task.yaml
reviewed_at: <ISO-8601-datetime>     # e.g. 2026-05-09T14:32:00Z

failures:
  - type: <contract-violation|scope-violation|missing-implementation|wrong-assertion-is-impl-bug|integration-failure-impl-bug|regression>
    # type must be in-lane for the layer (see references/feedback-taxonomy.md §2)
    location: <file:line>            # e.g. src/auth/TokenValidator.java:42
    description: <one-line description of what is wrong>
    required_fix: <concrete next step — junior-implementable without further lookup>
    spec_ref: <element-id or omit>   # e.g. FC-03, PRE-01, IFACE-07

required_fixes_summary: |
  # One paragraph summarising all failures.
  # Impl-leaf reads this as the entry point before walking the failures list.
  <summary paragraph>
