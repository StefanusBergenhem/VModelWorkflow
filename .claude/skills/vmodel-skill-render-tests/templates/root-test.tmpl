# File: tests/system/<<scope>>_system_test.go

```go
//go:build system

package system_test

import (
    "testing"
    "time"
    "github.com/stretchr/testify/assert"
    "github.com/stretchr/testify/require"
)

// VERIFIES: <<CASE_ID>> → <<VERIFIES_IDS>>
func TestSystem_<<TEST_NAME>>(t *testing.T) {
    // Arrange
    env := ConnectEnvironment(t, "<<ENVIRONMENT>>")
    tenant := env.CreateTestTenant("<<TENANT>>")
    session := env.AuthAs(tenant, "<<PERSONA>>")
    env.SetFeatureFlags(map[string]bool{
        "<<FEATURE_FLAG>>": true,
    })
    start := time.Now()

    // Act — user journey steps
    <<STEPS>>  // e.g.: session.SignUp(email, password)
               //        session.CreateProject("my-project")

    // Assert — user-visible / business-visible outcomes
    <<ASSERT>> // e.g.: assert.True(t, env.TenantExists(tenant.ID))
               //        assert.WithinDuration(t, time.Now(), emailSentAt, 60*time.Second)

    // Timing bound (if expected: specifies one)
    elapsed := time.Since(start)
    assert.LessOrEqual(t, elapsed.Minutes(), float64(5), "journey must complete within 5 minutes p95")
}
```

