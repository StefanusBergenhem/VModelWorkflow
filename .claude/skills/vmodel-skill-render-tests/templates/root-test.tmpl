import org.junit.jupiter.api.*;
import java.time.*;
import static org.assertj.core.api.Assertions.*;

@Tag("system")
@DisplayName("<<product-name>> — system")
class <<ScopeNamePascal>>SystemTest {

    Environment env;

    @BeforeEach
    void connect() {
        env = Environment.connect("<<ENVIRONMENT>>");
    }

    // VERIFIES: <<CASE_ID>> → <<VERIFIES_IDS>>
    @Test
    @DisplayName("<<case title>>")
    void test<<TEST_NAME>>() {
        // Arrange
        var tenant = env.createTestTenant("<<TENANT>>");
        var session = env.authAs(tenant, "<<PERSONA>>");
        env.setFeatureFlags(Map.of("<<FEATURE_FLAG>>", true));
        var start = Instant.now();

        // Act — user journey steps
        <<STEPS>> // e.g.: session.signUp(email, password);
                  //        session.createProject("my-project");

        // Assert — user-visible / business-visible outcomes
        <<ASSERT>> // e.g.: assertThat(env.tenantExists(tenant.getId())).isTrue();
                   //        assertThat(env.emailSentTo(tenant.getEmail()))
                   //            .isCompletedWithin(Duration.ofSeconds(60));

        // Timing bound
        var elapsed = Duration.between(start, Instant.now());
        assertThat(elapsed.toMinutes()).isLessThanOrEqualTo(5);
    }
}
