```typescript
import { describe, it, expect, beforeAll, afterAll } from 'vitest'
import { Environment } from '<<driver>>'

describe('<<product-name>> — system', () => {
  let env: Environment

  beforeAll(async () => {
    env = await Environment.connect('<<ENVIRONMENT>>')
  })

  afterAll(async () => {
    await env.cleanup()
  })

  // VERIFIES: <<CASE_ID>> → <<VERIFIES_IDS>>
  it('<<case title>>', async () => {
    // Arrange
    const tenant = await env.createTestTenant('<<TENANT>>')
    const session = await env.authAs(tenant, '<<PERSONA>>')
    await env.setFeatureFlags({ '<<FEATURE_FLAG>>': true })
    const start = Date.now()

    // Act — user journey steps
    <<STEPS>> // e.g.: await session.signUp({ email: 'test@example.com' })
              //        await session.createProject({ name: 'my-project' })

    // Assert — user-visible / business-visible outcomes
    <<ASSERT>> // e.g.: expect(await env.tenantExists(tenant.id)).toBe(true)
               //        expect(await env.emailSentTo(tenant.email, { withinSeconds: 60 })).toBe(true)

    // Timing bound
    const elapsedMs = Date.now() - start
    expect(elapsedMs).toBeLessThanOrEqualTo(5 * 60 * 1000)
  }, /* timeout: */ 10 * 60 * 1000)  // 10 min test timeout > 5 min journey bound

})
```

# ── Notes ────────────────────────────────────────────────────────
#
# Driver abstraction: the `Environment` / `session` object is the test driver.
# It wraps the product's entry points in user-vocabulary calls. The driver is
# NOT authored by this skill — it is a test infrastructure concern. If the driver
# does not exist yet, stub it with methods that throw NotImplementedError /
# UnsupportedOperationException so the test is red but parseable.
#
# Timing bounds: when expected: specifies a p95 bound and a single-run assertion
# is insufficient, note this in a comment and assert only the single-run upper
# bound (single run is a conservative check — p95 requires N runs).
#
# Feature flags: if preconditions: does not name any feature flags, omit the
# setFeatureFlags call entirely. Never invent flag names not in the TestSpec.
