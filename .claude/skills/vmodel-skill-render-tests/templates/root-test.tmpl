import pytest
import time
from <<driver>> import Environment

# VERIFIES: <<CASE_ID>> → <<VERIFIES_IDS>>
@pytest.mark.system
def test_<<test_name>>(system_env):
    """<<case title>>"""
    # Arrange
    tenant = system_env.create_test_tenant("<<TENANT>>")
    session = system_env.auth_as(tenant, persona="<<PERSONA>>")
    system_env.set_feature_flags({"<<FEATURE_FLAG>>": True})
    start = time.monotonic()

    # Act — user journey steps
    <<STEPS>>  # e.g.: session.sign_up(email="test@example.com", password="...")
               #        session.create_project(name="my-project")

    # Assert — user-visible / business-visible outcomes
    <<ASSERT>> # e.g.: assert system_env.tenant_exists(tenant.id)
               #        assert system_env.email_sent_to(tenant.email, within_seconds=60)

    # Timing bound
    elapsed = time.monotonic() - start
    assert elapsed <= 300, f"journey must complete within 5 min p95, got {elapsed:.1f}s"


@pytest.fixture(scope="session")
def system_env():
    env = Environment.connect("<<ENVIRONMENT>>")
    yield env
    env.cleanup()
