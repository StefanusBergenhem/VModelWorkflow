# Empty-scope rule (TARGET_ARCHITECTURE §5.4):
#   `<<scope-suffix?>>` is a conditional placeholder:
#     - At root scope (scope: ""), `<<scope-suffix?>>` expands to `` (empty string).
#     - At non-empty scope (e.g. scope: "app-checkout"), `<<scope-suffix?>>` expands to `-app-checkout`.
#   Concretely:
#     Artifact id:      `TS<<scope-suffix?>>`         → `TS`              at root  /  `TS-app-checkout` at branch
#     Per-case id:      `TC<<scope-suffix?>>-001`     → `TC-001`          at root  /  `TC-app-checkout-001` at branch
#     Dotted-path ref:  `ARCH<<scope-suffix?>>.interfaces.X`
#                                                     → `ARCH.interfaces.X` at root /  `ARCH-app-checkout.interfaces.X` at branch
#   Never emit a trailing dash with no scope (`TS-`, `TC--001`, `ARCH-.interfaces.X`); never emit a doubled dash (`TC--001`).
id: TS<<scope-suffix?>>
artifact_type: test-spec
scope: <<scope-path>>                    # e.g., session-store/expiry-calculator; "" at root
level: <<unit | integration | system>>   # leaf=unit, non-leaf=integration, root=system
verifies:
  - <<upstream-id-1>>                    # MUST be non-empty (refusal B)
  - <<upstream-id-2>>
governing_adrs:
  - <<ADR-NNN-name>>                     # omit if no governing ADRs apply
status: draft
date: <<YYYY-MM-DD>>
coverage_mutation_bar:                   # MUST be present (derived-hard refusal)
  structural_coverage:
    threshold_pct: <<number | "TBD-by-project-policy">>
    metric: <<line | branch | statement>>
  mutation_score:
    threshold_pct: <<number | "TBD-by-project-policy">>
    tool_category: <<PIT-class | Stryker-class | mutmut-class | "TBD-by-project-policy">>
  enforcement:
    frequency: <<per-PR | nightly | weekly | "TBD-by-project-policy">>
    blocking: <<true | false | "TBD-by-project-policy">>
# === RETROFIT-ONLY — uncomment for retrofit mode ===
# recovery_status:
#   verifies: unknown                    # default for reconstructed verifies links
---

