# .vmodel/config.yaml — V-model project configuration
# Generated by /vmodel-init. Edit to match your project.
# Template variables ({{VAR}}) are replaced during init.
# Field reference: VModelWorkflow/schemas/core/vmodel-config.schema.yaml

schema_version: "1.0"

# =============================================================================
# PROJECT
# =============================================================================

project:
  name: "{{PROJECT_NAME}}"
  language: "{{LANGUAGE}}"
  description: "{{DESCRIPTION}}"        # Optional — leave empty if not set
  scope_root: "{{SCOPE_ROOT}}"          # Default: specs/

# =============================================================================
# PATHS
# =============================================================================
#
# All paths relative to project root unless absolute.
# Skills resolve reference docs by filename under paths.references.

paths:
  references: ".vmodel/references/"
  reviews:    ".vmodel/.reviews/"
  build:      ".vmodel/.build/"
  defer_index: ".vmodel/defer-index.md"
  src:    "{{SRC_DIR}}"                 # Leave empty if build flow is unused
  tests:  "{{TESTS_DIR}}"              # Leave empty if build flow is unused

# =============================================================================
# ARTIFACTS
# =============================================================================

artifacts:
  root_product:
    type: "{{ROOT_PRODUCT_TYPE}}"       # pb | needs | pd (default: pd)
    file: "{{ROOT_PRODUCT_FILE}}"       # product_brief.md | needs.md | product_description.md

# =============================================================================
# COMMANDS
# =============================================================================
#
# Empty string ("") means "not configured — skip this step."
# Build-flow skills read these to execute the test/lint/build loop.

commands:
  test_unit:        "{{TEST_UNIT_CMD}}"
  test_integration: "{{TEST_INTEGRATION_CMD}}"
  test_system:      "{{TEST_SYSTEM_CMD}}"
  lint:             "{{LINT_CMD}}"
  build:            "{{BUILD_CMD}}"
  coverage:         "{{COVERAGE_CMD}}"

# =============================================================================
# BUILD FLOW
# =============================================================================
#
# Controls parallel task execution and model assignment for build-flow skills.

build:
  parallel:
    enabled:         {{BUILD_PARALLEL_ENABLED}}   # true | false
    max_concurrent:  {{BUILD_MAX_CONCURRENT}}      # Default: 4

  retry:
    max_review_attempts: {{BUILD_MAX_REVIEW_ATTEMPTS}}  # Default: 3

  models:
    plan:       "{{BUILD_MODEL_PLAN}}"        # Default: opus  (DAG derivation needs reasoning)
    implement:  "{{BUILD_MODEL_IMPLEMENT}}"   # Default: sonnet
    review:     "{{BUILD_MODEL_REVIEW}}"      # Default: sonnet
    retrospect: "{{BUILD_MODEL_RETROSPECT}}"  # Default: sonnet
