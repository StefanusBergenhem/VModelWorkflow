- id: REQ-<scope>-<NNN>
  type: functional
  statement: |
    # Pick one EARS pattern:
    #   Ubiquitous:        The <system> shall <response>.
    #   Event-driven:      When <trigger>, the <system> shall <response>.
    #   State-driven:      While <state>, the <system> shall <response>.
    #   Optional-feature:  Where <feature>, the <system> shall <response>.
    #   Unwanted-behaviour: If <condition>, then the <system> shall <response>.
    #
    # Compound limit: at most 2 keywords. Canonical order: Where → While → When → If/then.
    <statement>
  acceptance: |
    # Optional. Use when the statement alone leaves conditions ambiguous.
    # Given-When-Then form.
    Given <state>
    When <trigger>
    Then <observable response>
  rationale: |
    # WHY — option chosen, alternatives considered, criterion. Not a restatement.
    # If unrecoverable: mark `pending` (greenfield) or `unknown` (retrofit).
    <rationale>
  derived_from:
    - <upstream stakeholder need / parent requirement / product brief outcome>
  # derivation: derived         # uncomment only for derived requirements
